<!DOCTYPE html>
<html>
<head>
  <title>For My Bestie 💞</title>

  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: linear-gradient(to bottom, #ffd6e8, #fff);
      overflow: hidden;
      text-align: center;
    }

    /* Floating hearts */
    .heart {
      position: absolute;
      color: pink;
      font-size: 20px;
      animation: float 6s linear infinite;
    }

    @keyframes float {
      0% {transform: translateY(100vh);}
      100% {transform: translateY(-10vh);}
    }

    /* Button */
    .open-btn {
      margin-top: 40vh;
      padding: 15px 25px;
      border: none;
      border-radius: 30px;
      background: #ff69b4;
      color: white;
      font-size: 18px;
      cursor: pointer;
      box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }

    /* Letter card */
    .card {
      display: none;
      background: white;
      border-radius: 20px;
      padding: 20px;
      max-width: 350px;
      margin: auto;
      margin-top: 50px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.1);
      animation: fadeIn 1s ease-in-out;
    }

    img {
      width: 100%;
      border-radius: 15px;
      margin-bottom: 15px;
    }

    h1 { color: #ff69b4; }

    p {
      font-size: 14px;
      line-height: 1.6;
      color: #444;
    }

    @keyframes fadeIn {
      from {opacity: 0; transform: scale(0.9);}
      to {opacity: 1; transform: scale(1);}
    }
  </style>
</head>

<body>

<button class="open-btn" onclick="openLetter()">💌 Open Letter</button>

<div class="card" id="letter">
  <h1>💞 For My Bestie 💞</h1>

  <img src="https://drive.google.com/uc?id=1XPG5am5goG0ownsAQkgWcO71s2G5U7rS">

  <p>
  I wish you the best in life, Nin 🥺💗<br><br>
  Unta magkamo na ni Ross… joke HAHAHA 😆<br><br>
  Basta, always take care ha. I want you to have a good and bountiful life always ✨<br><br>
  Amping always min, and please eat properly para magka-unod imong lawas 😤💞<br><br>
  Thank you for all the memories, laughs, and everything 🫶<br><br>
  Again, amping always… and goodbye for now 👋💕💕💯
  </p>

  <p><b>— Your forever bestie 💗</b></p>
</div>

<!-- Background Music -->
<audio id="music" loop>
  <source src="https://www.bensound.com/bensound-music/bensound-love.mp3" type="audio/mp3">
</audio>

<script>
  function openLetter() {
    document.querySelector(".open-btn").style.display = "none";
    document.getElementById("letter").style.display = "block";
    document.getElementById("music").play();
  }

  // Create floating hearts
  setInterval(() => {
    let heart = document.createElement("div");
    heart.className = "heart";
    heart.innerHTML = "💗";
    heart.style.left = Math.random() * 100 + "vw";
    heart.style.fontSize = (Math.random() * 20 + 10) + "px";
    document.body.appendChild(heart);

    setTimeout(() => { heart.remove(); }, 6000);
  }, 500);
</script>

</body>
</html>
